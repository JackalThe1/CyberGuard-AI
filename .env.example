# ─────────────────────────────────────────────────────────────
# CyberGuard AI  –  Environment Configuration
# ─────────────────────────────────────────────────────────────

# AI Engine (REQUIRED for AI analysis — get free key at console.groq.com)
# Leave blank to run in heuristic-only mode
GROQ_API_KEY=your_groq_api_key_here

# ── Alert Channels (all optional) ────────────────────────────

# Slack  →  https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Discord  →  Server Settings › Integrations › Webhooks
DISCORD_WEBHOOK_URL=

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=cyberguard@yourdomain.com
EMAIL_TO=security@yourdomain.com

# ── Live Log Monitoring (optional) ───────────────────────────
# Default log path to monitor (leave blank for manual entry in UI)
# Linux:   /var/log/apache2/access.log
# macOS:   /var/log/apache2/access_log
# Windows: C:\inetpub\logs\LogFiles\W3SVC1\u_ex*.log
MONITOR_LOG_PATH=
